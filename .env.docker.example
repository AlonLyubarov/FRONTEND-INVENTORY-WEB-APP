# Copy this file to ".env" (same folder as docker-compose.yml) and fill in values.
# docker compose reads ".env" automatically for variable substitution.

# ── Host port the app is served on (browser opens http://localhost:WEB_PORT) ─
WEB_PORT=8080

# ── SQL Server SA password ──────────────────────────────────────────────────
# Must meet SQL Server complexity: 8+ chars, upper + lower + digit + symbol.
DB_PASSWORD=Your_Strong_Passw0rd!

# ── JWT signing key (64+ random characters recommended) ─────────────────────
JWT_KEY=change-me-to-a-long-random-secret-of-at-least-64-characters-please

# ── Geocoding/routing contact email (Nominatim/OSRM User-Agent) ─────────────
GEO_CONTACT_EMAIL=you@example.com

# ── Login gate ──────────────────────────────────────────────────────────────
# Require email verification before login. Keep false while email is log-only
# (users never receive the link); set true once a real SMTP sender is configured.
REQUIRE_EMAIL_VERIFICATION=false

# ── Email (SMTP) — leave EMAIL_HOST empty to log verification links only ────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_SSL=true
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
